# Copy this template to a git-ignored *.local file and source it before smoke
# or training. Keep machine-specific paths in that local copy.

AGENTARK_SWIFT_PYTHON=/path/to/swift-python/bin/python
# Local directory or model ID supported by the installed Swift/vLLM stack.
AGENTARK_MODEL=/path/to/multimodal-agent-model

AGENTARK_PYTHON_BIN=/path/to/agentark-python/bin/python
AGENTARK_RUNTIME_CONFIG=/path/to/agentark_runtime_config.yaml
# run_agentark_server.sh derives its default bind host/port from this URL.
AGENTARK_SERVER_URL=http://127.0.0.1:18080
AGENTARK_PROTOCOL_VERSION=v2
AGENTARK_HEARTBEAT_TIMEOUT=5

# Minimal one-step smoke. Increase these values only after the smoke passes.
AGENTARK_MAX_STEPS=1
AGENTARK_PER_DEVICE_TRAIN_BATCH_SIZE=2
AGENTARK_WORLD_SIZE=1
AGENTARK_GRADIENT_ACCUMULATION_STEPS=1
AGENTARK_NUM_GENERATIONS=2
AGENTARK_NUM_ITERATIONS=1
AGENTARK_TICKET_RESERVE_PERCENT=10

AGENTARK_MAX_TURNS=2
AGENTARK_MAX_LENGTH=6144
AGENTARK_MAX_COMPLETION_LENGTH=512
# Defaults to AGENTARK_MAX_LENGTH + AGENTARK_MAX_COMPLETION_LENGTH.
# AGENTARK_VLLM_MAX_MODEL_LEN=6656
AGENTARK_VLLM_GPU_MEMORY_UTILIZATION=0.30
AGENTARK_ASSISTANT_LOSS_SCOPE=all_turns

# Training mode and model-specific settings. LoRA is the low-memory quickstart.
AGENTARK_TUNER_TYPE=lora
AGENTARK_TORCH_DTYPE=bfloat16
# Launcher defaults: 1e-5 for LoRA and 1e-6 for full.
# AGENTARK_LEARNING_RATE=1e-5
AGENTARK_LORA_RANK=8
AGENTARK_LORA_ALPHA=16

# Set these when the selected model/template needs explicit values.
# AGENTARK_ENABLE_THINKING=false
# AGENTARK_FREEZE_VIT=true
# AGENTARK_FREEZE_ALIGNER=true
# AGENTARK_FREEZE_LLM=false

# Full-parameter example. Training every multimodal component requires all
# three freeze flags to be false. Size the GPU memory and checkpoint storage
# for the selected model before enabling it.
# AGENTARK_TUNER_TYPE=full
# AGENTARK_LEARNING_RATE=1e-6
# AGENTARK_OPTIM=adafactor
# AGENTARK_GRADIENT_CHECKPOINTING=true
# AGENTARK_FREEZE_VIT=false
# AGENTARK_FREEZE_ALIGNER=false
# AGENTARK_FREEZE_LLM=false

# Optional task selection. With task_name and no explicit seed, ticket
# generation derives a stable, distinct seed for each group.
# AGENTARK_TASK_NAME=Pushbox
# AGENTARK_GROUP_SEED=1234
# AGENTARK_GROUP_SEED_BASE=100000

# Formal runs should use a persistent output path and a stable run ID.
# AGENTARK_RUN_ID=run-001
# AGENTARK_OUTPUT_DIR=/path/to/output
# CUDA_VISIBLE_DEVICES=0
