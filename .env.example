# Copy to .env for local development. The AgentArk Python package auto-loads
# this file from the current working directory or one of its parents.
# Explicitly exported shell/CI variables take precedence.
# The Python package expands these variables in AgentArk YAML path fields.

# AgentArk runtime executable.
# Linux example:
AGENTARK_ENV_PATH=/path/to/agentark-build/AgentArk.x86_64
# Windows example:
# AGENTARK_ENV_PATH=C:\path\to\agentark-build

# Mods directory inside the AgentArk runtime build.
# Linux example:
AGENTARK_MOD_PATH=/path/to/agentark-build/AgentArk_Data/Resources/Mods
# Windows example:
# AGENTARK_MOD_PATH=C:\path\to\agentark-build\AgentArk_Data\Resources\Mods

# Shared task store used by runtime_sandbox.
AGENTARK_TASK_STORE_PATH=${AGENTARK_MOD_PATH}/all_tasks

# Optional local/multi-worktree Unity ML-Agents port overrides. Normal AgentArk
# users do not need to set these; omitting them preserves the existing Mods
# config/default behavior. Editor mode is selected when env_path=None, while a
# packaged Player is selected when env_path points to a build. Explicit
# cfg.base_port / --base-port values take precedence.
# AGENTARK_EDITOR_BASE_PORT=5004
# AGENTARK_PLAYER_BASE_PORT=5005

# Runtime template root and worker pool root used by runtime_sandbox.
AGENTARK_RUNTIME_TEMPLATE_ROOT=/path/to/agentark-build
AGENTARK_RUNTIME_POOL_ROOT=/tmp/agentark_runtime_pool

# Python 3.10 interpreter used for AgentArk runtime/eval/server processes.
MLAGENTS_PYTHON_BIN=/path/to/python3.10

# Optional Python interpreter used by an RL trainer such as VERL. This process
# talks to AgentArk through the env server, so it may follow the RL stack's
# Python version.
# VERL_PYTHON_BIN=/path/to/verl/python

# Optional OpenAI-compatible provider keys.
# OPENROUTER_API_KEY=
# DASHSCOPE_API_KEY=
# OPENAI_API_KEY=
